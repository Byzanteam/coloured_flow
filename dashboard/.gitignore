# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
coloured_flow_dashboard-*.tar

# Dialyzer PLTs (the directory itself is checked in via .gitkeep).
/priv/plts/*.plt
/priv/plts/*.plt.hash

# SPA build output — produced by `cd ui && pnpm build`. Sources live in
# `ui/`; static assets are emitted to `priv/static/{index.html,assets/*,
# favicon.ico,robots.txt}` and never checked in.
/priv/static/

# SPA-generated bundles. The `:musubi_ts` Mix compiler rewrites this on every
# `mix compile`, so the on-disk copy is always derivable from store sources.
/ui/src/generated/musubi.d.ts


